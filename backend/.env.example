# ==============================
# Core server
# ==============================
PORT=5050
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# ==============================
# Supabase (required)
# IMPORTANT: backend should use SERVICE ROLE for RLS-protected tables
# ==============================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ==============================
# Auth / sessions
# ==============================
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_TOKEN_TTL_SECONDS=43200
STUDENT_TOKEN_TTL_SECONDS=43200

# ==============================
# Caches / performance (optional)
# ==============================
QUESTION_COUNTS_CACHE_TTL_MS=300000
ACTIVE_SESSION_CACHE_TTL_MS=7200000
ACTIVE_SESSION_CACHE_MAX_SIZE=1000
STUDENT_CACHE_TTL_MS=300000
DEMO_SESSION_CACHE_TTL_MS=7200000
DEMO_SESSION_CACHE_MAX_SIZE=5000
DEMO_CATALOG_CACHE_TTL_MS=600000
DEMO_QUESTION_PAYLOAD_CACHE_TTL_MS=1800000
DEMO_QUESTION_PAYLOAD_CACHE_MAX_SIZE=100

# ==============================
# Railway video catalog (optional but required for Manas videos)
# ==============================
# Use Railway Postgres URL or any dedicated Postgres for video metadata.
RAILWAY_VIDEO_DATABASE_URL=postgresql://postgres:password@host:5432/railway

# Public CDN/storage prefix for published videos.
# Example: https://cdn.example.com/promanas-manas
VIDEO_PUBLIC_BASE_URL=

# Local preview only for development. Do not use this in production for heavy traffic.
VIDEO_LIBRARY_ROOT=
ALLOW_LOCAL_VIDEO_PREVIEW=false

# Secure proxy grants for student video playback (seconds).
VIDEO_GRANT_TTL_SECONDS=1800
VIDEO_SEGMENT_GRANT_TTL_SECONDS=300
VIDEO_GRANT_STORE_MAX_SIZE=50000
VIDEO_GRANT_PRUNE_INTERVAL_MS=30000
